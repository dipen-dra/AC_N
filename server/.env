# Server Configuration
NODE_ENV=development
PORT=5001

# Database (support both common names)
MONGO_URI=mongodb://127.0.0.1:27017/autocare_nepal
MONGODB_URI=mongodb://127.0.0.1:27017/autocare_nepal

# JWT
JWT_SECRET=autocare_secret_key_123456

# Cookie
COOKIE_DOMAIN=192.168.1.103

# CORS
CLIENT_URL=http://192.168.1.103:5173

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
